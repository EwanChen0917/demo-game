{
  "name": "demo-game",
  "version": "0.0.1",
  "description": "世家模拟经营游戏 — Vue 3 + Phaser 3 + Pinia + Electron",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "electron:dev": "vite --mode electron",
    "electron:build": "vite build && electron-builder"
  },
  "dependencies": {
    "phaser": "^3.80.0",
    "pinia": "^2.2.0",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.0",
    "cn-atlas": "^0.1.2",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "~5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0",
    "vue-tsc": "^2.2.0"
  },
  "build": {
    "appId": "com.demo-game",
    "productName": "demo-game",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
